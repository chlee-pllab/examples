--- |
  ; ModuleID = 'add_kernel.llir'
  source_filename = "LLVMDialectModule"
  target datalayout = "e-m:e-p:64:64-i64:64-i128:128-n32:64-S128"
  target triple = "riscv64-unknown-linux-gnu"
  
  ; Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(argmem: readwrite)
  define void @add_kernel(ptr readonly captures(none) %0, ptr readonly captures(none) %1, ptr writeonly captures(none) %2, i32 %3, i32 %4, i32 %5, i32 %6, i32 %7, i32 %8, i32 %9) local_unnamed_addr #0 !dbg !3 {
    %11 = shl i32 %4, 7, !dbg !6
    %12 = insertelement <128 x i32> poison, i32 %11, i64 0, !dbg !7
    %13 = shufflevector <128 x i32> %12, <128 x i32> poison, <128 x i32> zeroinitializer, !dbg !7
    %14 = or disjoint <128 x i32> %13, <i32 0, i32 1, i32 2, i32 3, i32 4, i32 5, i32 6, i32 7, i32 8, i32 9, i32 10, i32 11, i32 12, i32 13, i32 14, i32 15, i32 16, i32 17, i32 18, i32 19, i32 20, i32 21, i32 22, i32 23, i32 24, i32 25, i32 26, i32 27, i32 28, i32 29, i32 30, i32 31, i32 32, i32 33, i32 34, i32 35, i32 36, i32 37, i32 38, i32 39, i32 40, i32 41, i32 42, i32 43, i32 44, i32 45, i32 46, i32 47, i32 48, i32 49, i32 50, i32 51, i32 52, i32 53, i32 54, i32 55, i32 56, i32 57, i32 58, i32 59, i32 60, i32 61, i32 62, i32 63, i32 64, i32 65, i32 66, i32 67, i32 68, i32 69, i32 70, i32 71, i32 72, i32 73, i32 74, i32 75, i32 76, i32 77, i32 78, i32 79, i32 80, i32 81, i32 82, i32 83, i32 84, i32 85, i32 86, i32 87, i32 88, i32 89, i32 90, i32 91, i32 92, i32 93, i32 94, i32 95, i32 96, i32 97, i32 98, i32 99, i32 100, i32 101, i32 102, i32 103, i32 104, i32 105, i32 106, i32 107, i32 108, i32 109, i32 110, i32 111, i32 112, i32 113, i32 114, i32 115, i32 116, i32 117, i32 118, i32 119, i32 120, i32 121, i32 122, i32 123, i32 124, i32 125, i32 126, i32 127>, !dbg !7
    %15 = insertelement <128 x i32> poison, i32 %3, i64 0, !dbg !8
    %16 = shufflevector <128 x i32> %15, <128 x i32> poison, <128 x i32> zeroinitializer, !dbg !8
    %17 = icmp slt <128 x i32> %14, %16, !dbg !8
    %18 = sext i32 %11 to i64, !dbg !9
    %19 = getelementptr float, ptr %0, i64 %18, !dbg !9
    %20 = tail call <128 x float> @llvm.masked.load.v128f32.p0(ptr %19, i32 4, <128 x i1> %17, <128 x float> zeroinitializer), !dbg !10
    %21 = getelementptr float, ptr %1, i64 %18, !dbg !11
    %22 = tail call <128 x float> @llvm.masked.load.v128f32.p0(ptr %21, i32 4, <128 x i1> %17, <128 x float> zeroinitializer), !dbg !12
    %23 = fadd <128 x float> %20, %22, !dbg !13
    %24 = getelementptr float, ptr %2, i64 %18, !dbg !14
    tail call void @llvm.masked.store.v128f32.p0(<128 x float> %23, ptr %24, i32 4, <128 x i1> %17), !dbg !15
    ret void, !dbg !16
  }
  
  ; Function Attrs: nocallback nofree nosync nounwind willreturn memory(argmem: read)
  declare <128 x float> @llvm.masked.load.v128f32.p0(ptr captures(none), i32 immarg, <128 x i1>, <128 x float>) #1
  
  ; Function Attrs: nocallback nofree nosync nounwind willreturn memory(argmem: write)
  declare void @llvm.masked.store.v128f32.p0(<128 x float>, ptr captures(none), i32 immarg, <128 x i1>) #2
  
  attributes #0 = { mustprogress nofree norecurse nosync nounwind willreturn memory(argmem: readwrite) "target-features"="+m,+f,+d,+v" }
  attributes #1 = { nocallback nofree nosync nounwind willreturn memory(argmem: read) "target-features"="+m,+f,+d,+v" }
  attributes #2 = { nocallback nofree nosync nounwind willreturn memory(argmem: write) "target-features"="+m,+f,+d,+v" }
  
  !llvm.dbg.cu = !{!0}
  !llvm.module.flags = !{!2}
  
  !0 = distinct !DICompileUnit(language: DW_LANG_C, file: !1, producer: "triton", isOptimized: true, runtimeVersion: 0, emissionKind: LineTablesOnly)
  !1 = !DIFile(filename: "01-vector-add.py", directory: "/home/chlee/triton-cpu/python/tutorials")
  !2 = !{i32 2, !"Debug Info Version", i32 3}
  !3 = distinct !DISubprogram(name: "add_kernel", linkageName: "add_kernel", scope: !1, file: !1, line: 35, type: !4, scopeLine: 35, spFlags: DISPFlagDefinition | DISPFlagOptimized, unit: !0)
  !4 = !DISubroutineType(cc: DW_CC_normal, types: !5)
  !5 = !{}
  !6 = !DILocation(line: 49, column: 24, scope: !3)
  !7 = !DILocation(line: 50, column: 28, scope: !3)
  !8 = !DILocation(line: 52, column: 21, scope: !3)
  !9 = !DILocation(line: 55, column: 24, scope: !3)
  !10 = !DILocation(line: 55, column: 16, scope: !3)
  !11 = !DILocation(line: 56, column: 24, scope: !3)
  !12 = !DILocation(line: 56, column: 16, scope: !3)
  !13 = !DILocation(line: 57, column: 17, scope: !3)
  !14 = !DILocation(line: 59, column: 26, scope: !3)
  !15 = !DILocation(line: 59, column: 35, scope: !3)
  !16 = !DILocation(line: 59, column: 4, scope: !3)
...
