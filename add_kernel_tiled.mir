    liveins: $x10, $x11, $x12, $x13, $x14
  
    renamable $x15 = COPY $x0
    renamable $x14 = SLLIW killed renamable $x14, 12,  debug-location !6
    renamable $x16 = ADDI $x0, 32
    dead $x0 = PseudoVSETVLI renamable $x16, 211 /* e32, m8, ta, ma */, implicit-def $vl, implicit-def $vtype
    renamable $v8m8 = PseudoVMV_V_I_M8 undef renamable $v8m8, 0, $noreg, 5 /* e32 */, 0 /* tu, mu */, implicit $vl, implicit $vtype
    renamable $x17 = ADDI $x0, 128
  
  bb.1 (%ir-block.13):
    successors: %bb.2(0x04000000), %bb.1(0x7c000000)
    liveins: $x10, $x11, $x12, $x13, $x14, $x15, $x16, $x17, $v8m8
  
    renamable $x5 = nuw nsw SLLI renamable $x15, 5,  debug-location !8
    $x0 = PseudoVSETVLI renamable $x16, 83 /* e32, m8, ta, mu */, implicit-def $vl, implicit-def $vtype,  debug-location !13
    renamable $v24m8 = COPY renamable $v8m8, implicit $vtype,  debug-location !13
