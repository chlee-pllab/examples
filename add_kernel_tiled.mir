    renamable $v16m8 = PseudoVID_V_M8 undef renamable $v16m8, $noreg, 5 /* e32 */, 1 /* ta, mu */, implicit $vl, implicit $vtype,  debug-location !10
    renamable $v16m8 = disjoint PseudoVOR_VX_M8 undef renamable $v16m8, killed renamable $v16m8, renamable $x5, $noreg, 5 /* e32 */, 1 /* ta, mu */, implicit $vl, implicit $vtype,  debug-location !10
    early-clobber renamable $v0 = PseudoVMSLT_VX_M8 killed renamable $v16m8, renamable $x13, $noreg, 5 /* e32 */, implicit $vl, implicit $vtype,  debug-location !11
    renamable $v16m8 = COPY renamable $v8m8, implicit $vtype,  debug-location !15
    renamable $x5 = SLLI killed renamable $x5, 2,  debug-location !12
    renamable $x6 = ADD renamable $x10, renamable $x5,  debug-location !12
    renamable $v24m8 = PseudoVLE32_V_M8_MASK killed renamable $v24m8, killed renamable $x6, $v0, $noreg, 5 /* e32 */, 1 /* ta, mu */, implicit $vl, implicit $vtype,  debug-location !13 :: (load unknown-size from %ir.23, align 4)
