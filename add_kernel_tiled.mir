    renamable $v16m8 = PseudoVLE32_V_M8_MASK killed renamable $v16m8, killed renamable $x6, $v0, $noreg, 5 /* e32 */, 1 /* ta, mu */, implicit $vl, implicit $vtype,  debug-location !15 :: (load unknown-size from %ir.25, align 4)
    renamable $v16m8 = PseudoVADD_VV_M8 undef renamable $v16m8, killed renamable $v16m8, killed renamable $v24m8, $noreg, 5 /* e32 */, 1 /* ta, mu */, implicit $vl, implicit $vtype,  debug-location !16
    renamable $x5 = ADD renamable $x12, killed renamable $x5,  debug-location !17
    renamable $x15 = nuw nsw ADDI killed renamable $x15, 1,  debug-location !7
